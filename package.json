{
  "name": "caf-gpt",
  "version": "1.0.0",
  "description": "A collection of AI tools and agents for CAF personnel",
  "scripts": {
    "start": "node dist/server/index.js",
    "dev": "nodemon --exec 'node' -r ts-node/register src/server/index.ts",
    "dev:server": "node -r ts-node/register src/server/index.ts",
    "dev:client": "npm run build:client -- --watch",
    "build": "tsc",
    "build:prod": "NODE_ENV=production npm run clean && concurrently \"npm:build:server:prod\" \"npm:build:client:prod\"",
    "build:server": "tsc -p tsconfig.json",
    "build:server:prod": "tsc -p tsconfig.json --removeComments",
    "build:client": "esbuild src/client/*.ts --bundle --outdir=public/js --sourcemap --format=cjs",
    "build:client:prod": "esbuild src/client/*.ts --bundle --outdir=public/js --minify --format=cjs",
    "clean": "rimraf dist public/js && mkdir -p dist public/js",
    "clean:all": "rimraf dist public/js node_modules coverage && mkdir -p dist public/js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:real": "cross-env USE_REAL_LLM_API=true USE_REAL_S3=true jest",
    "test:real:llm": "cross-env USE_REAL_LLM_API=true jest",
    "test:real:s3": "cross-env USE_REAL_S3=true jest",
    "test:verbose": "cross-env VERBOSE_TESTS=true jest",
    "test:utils": "jest src/test/utils",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "author": "",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@flydotio/dockerfile": "^0.7.8",
    "@types/http-server": "^0.12.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.7",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.3",
    "rimraf": "^6.0.1"
  }
}
