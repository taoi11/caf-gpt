{
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "types": "wrangler types --env-interface CloudflareBindings",
    "types:check": "wrangler types --check --env-interface CloudflareBindings",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "compile": "tsc --noEmit",
    "test": "vitest --run --reporter=dot --silent && vitest --run --config vitest.workers.config.mts --reporter=dot --silent",
    "test:watch": "vitest",
    "test:verbose": "vitest --run && vitest --run --config vitest.workers.config.mts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "agents": "^0.14.1",
    "ai": "^6.0.116",
    "html-to-text": "^9.0.5",
    "postal-mime": "^2.4.4",
    "workers-ai-provider": "^3.3.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.57.0"
  }
}
