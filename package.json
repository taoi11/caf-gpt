{
  "name": "caf-gpt",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "npm run clean && concurrently \"tsx watch src/index.ts\" \"npm run build:client -- --watch\"",
    "build": "npm run clean && npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json $NODE_ENV=production && --removeComments",
    "build:client": "esbuild src/client/*.ts --bundle --outdir=public/js --sourcemap --format=esm $NODE_ENV=production && --minify",
    "clean": "rm -rf dist public/js && mkdir -p dist public/js",
    "test": "jest --config jest.config.ts",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "author": "",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@types/http-server": "^0.12.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.4.5",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "dotenv": "^16.4.7"
  },
  "main": "index.js"
}
