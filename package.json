{
  "name": "caf-gpt",
  "version": "1.0.0",
  "description": "A collection of AI tools and agents for CAF personnel",
  "type": "module",
  "scripts": {
    "start": "node dist/server/index.js",
    "dev": "npm run clean && concurrently \"node --import tsx src/server/index.ts\" \"npm run build:client -- --watch\"",
    "dev:server": "node --import tsx src/server/index.ts",
    "dev:client": "npm run build:client -- --watch",
    
    "build": "npm run clean && concurrently \"npm:build:server\" \"npm:build:client\"",
    "build:prod": "NODE_ENV=production npm run clean && concurrently \"npm:build:server:prod\" \"npm:build:client:prod\"",
    "build:server": "tsc -p tsconfig.json",
    "build:server:prod": "tsc -p tsconfig.json --removeComments",
    "build:client": "esbuild src/client/*.ts --bundle --outdir=public/js --sourcemap --format=esm",
    "build:client:prod": "esbuild src/client/*.ts --bundle --outdir=public/js --minify --format=esm",
    
    "clean": "rimraf dist public/js && mkdir -p dist public/js",
    "clean:all": "rimraf dist public/js node_modules coverage && mkdir -p dist public/js",
    
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    
    "test": "node --import tsx node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:watch": "node --import tsx node_modules/jest/bin/jest.js --config jest.config.cjs --watch",
    "test:coverage": "node --import tsx node_modules/jest/bin/jest.js --config jest.config.cjs --coverage"
  },
  "author": "",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/http-server": "^0.12.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "dotenv": "^16.4.7",
    "rimraf": "^6.0.1"
  }
}
