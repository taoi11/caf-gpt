/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 *
 * Required secrets (set with: wrangler secret put <NAME>):
 * - CF_AIG_AUTH: Cloudflare AI Gateway authentication token
 * - EMAIL_SECRET: HMAC secret for signed Agents SDK email reply routing
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "caf-gpt-email",
  "account_id": "7101c0eb0cce7925fd15056c805c97eb",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-28",
  "compatibility_flags": ["nodejs_compat"],
  "limits": {
    "cpu_ms": 60000 // default is 30000 (30 seconds)
  },
  "placement": {
    "mode": "smart"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "html_handling": "auto-trailing-slash"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 0.05
    }
  },
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "policies"
    }
  ],
  "send_email": [
    {
      "name": "EMAIL",
      "remote": true,
      "allowed_sender_addresses": ["agent@caf-gpt.com", "pacenote@caf-gpt.com"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "UserAgent",
        "class_name": "UserAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["UserAgent"]
    }
  ]
}
